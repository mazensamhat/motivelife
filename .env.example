# ─── Launch stack (keep it stupid simple) ───────────────────────────────────
# GitHub → Vercel → Supabase → OpenAI (optional)
#
# NOT used: AWS, Redis, RabbitMQ, queues, ElasticSearch, Kubernetes, microservices.

# Supabase Postgres (Settings → Database → Connection string)
# Pooled URL for the app (port 6543, ?pgbouncer=true):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for Prisma db push (port 5432):
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret"

# Admin ops console — comma-separated emails that redirect to /admin on login
ADMIN_EMAILS="you@example.com"

# MotiveFX Ops link from MotiveLife /admin (new tab). Local dev example:
# NEXT_PUBLIC_MOTIVEFX_OPS_URL="http://127.0.0.1:5280/?view=admin"
NEXT_PUBLIC_MOTIVEFX_OPS_URL="https://motivefx.ai/?view=admin"

# OpenAI — OPTIONAL at launch. Leave empty = $0 AI spend (rule-based briefing works fine).
OPENAI_API_KEY=""
# Set to "false" to disable AI even when a key is present (staging / cost freeze)
ENABLE_OPENAI="true"

# Stripe — MotiveLife Pro ($14.99/mo)
# Secret key: Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY=""
# Recommended: set Lookup key on your price in Product catalog, then paste it here
STRIPE_PRICE_LOOKUP_KEY=""
# Or use a Price ID directly (price_...) instead of lookup key
STRIPE_PRICE_ID=""
# Local: run `stripe listen --forward-to localhost:3002/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=""

# App — production: https://www.mymotivelife.com
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# Password reset emails (Resend — https://resend.com)
RESEND_API_KEY=""
# Verify your domain in Resend, then e.g. MotiveLife <hello@mymotivelife.com>
EMAIL_FROM="MotiveLife <hello@mymotivelife.com>"

# Google Calendar (optional — /integrations)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3002/api/integrations/google/callback"
