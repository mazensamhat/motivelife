{
  "name": "forward",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @forward/database db:generate",
    "db:push": "pnpm --filter @forward/database db:push",
    "db:studio": "pnpm --filter @forward/database db:studio",
    "db:reset-password": "node packages/database/scripts/reset-user-password.mjs",
    "db:grant-pro": "node packages/database/scripts/grant-pro.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
